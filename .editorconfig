root = true

[*]
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true
indent_style = space
indent_size = 4

[*.md]
trim_trailing_whitespace = false
indent_size = 2

[Makefile]
indent_style = tab

[*.go]
indent_style = tab
indent_size = 4

[*.{yml,yaml}]
indent_size = 2

[*.{ts,tsx,js,jsx,json,css,scss,html}]
indent_size = 2
