#!/usr/bin/env bash
set -euo pipefail

die() {
    printf 'Error: %s\n' "$*" >&2
    exit 1
}

command -v fzf >/dev/null 2>&1 || die "fzf is required."

git rev-parse --is-inside-work-tree >/dev/null 2>&1 || die "Run inside a Git repository."

current="$(git symbolic-ref --short HEAD 2>/dev/null || true)"

set +e
selected="$(
    git branch --sort=-committerdate \
        --format='%(HEAD) %(refname:short)%09%(objectname:short)%09%(subject)%09%(committerdate:relative)' |
        sed 's/^\* /\* /;s/^  /  /' |
        fzf --ansi \
            --delimiter=$'\t' \
            --with-nth=1,3,4 \
            --height=80% --layout=reverse --tiebreak=index \
            --preview 'git log --color=always --oneline -20 "$(echo {1} | sed s/^\*// | tr -d " ")"' \
            --preview-window=right:50%:wrap \
            --exit-0
)"
rc=$?
set -e

case "$rc" in
0) : ;;
1 | 130) exit 0 ;;
*) die "fzf failed (exit code $rc)" ;;
esac

[[ -n "$selected" ]] || exit 0

branch="$(printf '%s' "$selected" | cut -f1 | sed 's/^\*//' | tr -d ' ')"

[[ "$branch" == "$current" ]] && { printf 'Already on %s\n' "$branch"; exit 0; }

git checkout "$branch"
