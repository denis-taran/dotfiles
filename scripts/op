#!/usr/bin/env bash

if ! grep -qi microsoft /proc/version 2>/dev/null; then
    for _op in /usr/bin/op /usr/local/bin/op; do
        [[ -x "$_op" ]] && exec "$_op" "$@"
    done
    echo "Please install 1Password CLI." >&2
    exit 1
fi

WIN_OP_BASE="$(wslpath "$(cmd.exe /c echo %USERPROFILE% 2>/dev/null | tr -d '\r')")/AppData/Local/Microsoft/WinGet/Packages"
OP_DIR=$(find "$WIN_OP_BASE" -maxdepth 1 -name 'AgileBits.1Password.CLI*' -type d 2>/dev/null | sort -r | head -n1)

if [[ -z "$OP_DIR" ]]; then
    echo "Please install 1Password CLI on Windows with: winget install AgileBits.1Password.CLI" >&2
    exit 1
fi

mapfile -d '' op_env_vars < <(env -0 | grep -z ^OP_ | cut -z -d= -f1)
if [[ ${#op_env_vars[@]} -gt 0 ]]; then
    WSLENV="${WSLENV:-}:$(
        IFS=:
        echo "${op_env_vars[*]}"
    )"
    export WSLENV
fi

exec "$OP_DIR/op.exe" "$@"
