[Unit]
Description=Code folder backup

[Service]
Type=oneshot
User=%i
LoadCredential=encryption-pub-key:/etc/credstore/code-encryption-pub-key
ExecStart=/usr/local/libexec/dotfiles/code-backup.sh

# Sandboxing (common directives appended from lib/sandbox.conf at install time)
RestrictAddressFamilies=AF_UNIX
