[include]
    path = ~/.config/git/local
[commit]
    gpgsign = false
[pull]
    rebase = true
[branch]
    autosetuprebase = always
    sort = -committerdate
[push]
    default = current
    autoSetupRemote = true
[core]
    attributesFile = ~/.config/git/attributes
	excludesfile = ~/.config/git/ignore
	autocrlf = input
	ignorecase = false
    symlinks = true
[color]
	ui = true
[color "diff-highlight"]
	oldNormal = red bold
	oldHighlight = red bold 52
	newNormal = green bold
	newHighlight = green bold 22
[color "diff"]
	meta = 11
	frag = magenta bold
	commit = yellow bold
	old = red bold
	new = green bold
	whitespace = red reverse
	func = 146 bold
[init]
	defaultBranch = main
[fetch]
    prune = true
    pruneTags = true
[diff]
    algorithm = histogram
    colorMoved = default
[rerere]
    enabled = true
[merge]
    conflictstyle = zdiff3
[rebase]
    autoSquash = true
    autoStash = true
    updateRefs = true
[tag]
    sort = version:refname
[filter "lfs"]
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
	clean = git-lfs clean -- %f

[includeIf "gitdir:~/Code/autocomplete/"]
	path = ~/Code/dotfiles/.config/git/sign-on
[includeIf "gitdir:~/Code/unobtrusive-validation/"]
	path = ~/Code/dotfiles/.config/git/sign-on
[includeIf "gitdir:~/Code/dotfiles/"]
	path = ~/Code/dotfiles/.config/git/sign-on
