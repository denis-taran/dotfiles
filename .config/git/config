[include]
    path = ~/.config/git/local
[pull]
    rebase = true
[branch]
    autosetuprebase = always
    sort = -committerdate
[push]
    default = current
    autoSetupRemote = true
[core]
    attributesFile = ~/.config/git/attributes
	excludesfile = ~/.config/git/ignore
	autocrlf = input
	ignorecase = false
    symlinks = true
    pager = delta
[interactive]
    diffFilter = delta --color-only
[delta]
    line-numbers = true
    navigate = true
    dark = true
[init]
	defaultBranch = main
[fetch]
    prune = true
    pruneTags = true
[diff]
    algorithm = histogram
    colorMoved = default
[rerere]
    enabled = true
[merge]
    conflictstyle = zdiff3
[rebase]
    autoSquash = true
    autoStash = true
    updateRefs = true
[tag]
    sort = version:refname
[filter "lfs"]
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
	clean = git-lfs clean -- %f
